# ──────────────────────────────────────────────
# ValueSentinel Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Database ──
# PostgreSQL credentials (used by docker-compose.yml)
POSTGRES_USER=valuesentinel
POSTGRES_PASSWORD=changeme
POSTGRES_DB=valuesentinel
# SQLite (default for dev): sqlite:///data/valuesentinel.db
# PostgreSQL (prod):        postgresql://user:pass@localhost:5432/valuesentinel
# NOTE: In Docker mode, DATABASE_URL is built automatically from POSTGRES_* vars above.
#       Only set this directly for local / bare-metal deployments.
DATABASE_URL=sqlite:///data/valuesentinel.db

# ── Check Loop ──
# Interval in minutes: 5, 15 (default), 30, 60
CHECK_INTERVAL_MINUTES=15

# ── Notification: Telegram ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Notification: Discord ──
DISCORD_WEBHOOK_URL=

# ── Notification: Email (SMTP) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_TO_ADDRESS=

# ── Notification: Pushover ──
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=

# ── Interactive Brokers (optional) ──
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# ── Logging ──
LOG_LEVEL=INFO
LOG_FILE=logs/valuesentinel.log
